{
    "version": "0.1.0",
    "schema_version": "1.0",
    "api": {
        "host": "0.0.0.0",
        "port": 8100
    },
    "llm": {
        "provider": "openai",
        "model": "gpt-4o-mini",
        "temperature": 0.1,
        "timeout_seconds": 30
    },
    "embedding": {
        "provider": "openai",
        "model": "text-embedding-3-small",
        "dimensions": 1536
    },
    "vector_store": {
        "backend": "pgvector",
        "table": "articles",
        "retrieval_top_k": 12,
        "recency_window_minutes": 1440
    },
    "log_level": "INFO"
}
