{
    "version": "0.3.1",
    "schema_version": "1.0",
    "api": {
        "host": "0.0.0.0",
        "port": 8100
    },
    "llm": {
        "provider": "openai",
        "temperature": 0.1,
        "timeout_seconds": 30,
        "allowed_models": [
            "gpt-4o-mini",
            "gpt-4o"
        ],
        "base_url": null
    },
    "embedding": {
        "provider": "openai",
        "model": "text-embedding-3-small",
        "dimensions": 1536
    },
    "vector_store": {
        "backend": "pgvector",
        "retrieval_top_k": 12,
        "recency_window_minutes": 1440
    },
    "pricing": {
        "currency": "USD",
        "models": {
            "text-embedding-3-small": {
                "input_per_1k": 2e-05,
                "output_per_1k": 0.0
            },
            "text-embedding-3-large": {
                "input_per_1k": 0.00013,
                "output_per_1k": 0.0
            },
            "gpt-4o-mini": {
                "input_per_1k": 0.00015,
                "output_per_1k": 0.0006
            },
            "gpt-4o": {
                "input_per_1k": 0.0025,
                "output_per_1k": 0.01
            }
        }
    },
    "cost": {
        "account_credit_usd": 0.0,
        "budget_usd": 0.0,
        "circuit_breaker": {
            "enabled": true,
            "reprobe_interval_seconds": 120,
            "soft_daily_usd": 0.0
        }
    },
    "log_level": "INFO",
    "logging": {
        "file": "logs/finiex.log",
        "rotation": "daily",
        "backup_count": 14,
        "max_bytes": 10000000,
        "quiet_loggers": [
            "httpx",
            "httpcore"
        ],
        "warn_on_override": true
    },
    "source_health": {
        "flag_after_consecutive_failures": 5,
        "quarantine_hours": 24,
        "recent_events_kept": 10
    },
    "telegram": {
        "enabled": false,
        "bot_token": "",
        "chat_id": "",
        "poll_interval_seconds": 30,
        "commands_enabled": false,
        "report_command": "/report"
    },
    "weekly_report": {
        "enabled": false,
        "day_of_week": "sun",
        "hour": 18,
        "minute": 0,
        "timezone": "UTC",
        "export_outcomes": true,
        "export_dir": "data/signal_export"
    }
}