{
    // FiniexRAGEngine — debug / run entry points
    "version": "0.2.0",
    "configurations": [
        // ====================================================
        // 🚀 SERVICE (run the engine)
        // ====================================================
        {
            "name": "🚀 RAGEngine: API Server (reload)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/finiexragengine/cli/server_cli.py",
            "args": [
                "--reload",
                "--port",
                "8100"
            ],
            "console": "integratedTerminal",
            "justMyCode": false,
            "presentation": {
                "group": "01_service",
                "order": 1
            }
        },
        {
            // Live mode (ISSUE_10): background ingest+eval workers on their own
            // cadences — continuous paid activity, run deliberately.
            "name": "💸 RAGEngine: API Server + Workers (live, paid)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/finiexragengine/cli/server_cli.py",
            "args": [
                "--workers",
                "--port",
                "8100"
            ],
            "console": "integratedTerminal",
            "justMyCode": false,
            "presentation": {
                "group": "01_service",
                "order": 2
            }
        },
        {
            // + the live terminal dashboard (ISSUE_26): needs a TTY; console logs move to
            // the rotating file so rich.Live owns the terminal exclusively.
            "name": "🖥️💸 RAGEngine: API Server + Workers + Live Display (paid)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/finiexragengine/cli/server_cli.py",
            "args": [
                "--workers",
                "--live",
                "--port",
                "8100"
            ],
            "console": "integratedTerminal",
            "justMyCode": false,
            "presentation": {
                "group": "01_service",
                "order": 3
            }
        },
        // ====================================================
        // ⚙️ STAGE CLIs (real OpenAI API cost — a single stage, run deliberately)
        // ====================================================
        {
            "name": "💸 RAGEngine: Run Pipeline (full envelope, paid)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/finiexragengine/cli/run_cli.py",
            "args": [
                "--pipeline",
                "${input:pipeline}"
            ],
            "console": "integratedTerminal",
            "justMyCode": false,
            "presentation": {
                "group": "03_stage_clis",
                "order": 1
            }
        },
        {
            "name": "💸 RAGEngine: Ingest (fetch→embed→upsert, paid)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/finiexragengine/cli/ingest_cli.py",
            "args": [
                "--source-set",
                "${input:source_set}"
            ],
            "console": "integratedTerminal",
            "justMyCode": false,
            "presentation": {
                "group": "03_stage_clis",
                "order": 2
            }
        },
        {
            "name": "💸 RAGEngine: Evaluate Symbol (signal + prompt, paid)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/finiexragengine/cli/eval_cli.py",
            "args": [
                "--pipeline",
                "${input:pipeline}",
                "--symbol",
                "${input:symbol}"
            ],
            "console": "integratedTerminal",
            "justMyCode": false,
            "presentation": {
                "group": "03_stage_clis",
                "order": 3
            }
        },
        {
            // Variant fan-out (ISSUE_42): a variant stream is an ordinary pipeline_id —
            // this entry just composes it (<pipeline>_<variant>) from two prompts.
            "name": "💸 RAGEngine: Evaluate Symbol @ variant (paid)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/finiexragengine/cli/eval_cli.py",
            "args": [
                "--pipeline",
                "${input:pipeline}_${input:variant}",
                "--symbol",
                "${input:symbol}"
            ],
            "console": "integratedTerminal",
            "justMyCode": false,
            "presentation": {
                "group": "03_stage_clis",
                "order": 4
            }
        },
        // ====================================================
        // 📊 DIAGNOSTICS (read-only DB reports — free on cached query vectors)
        // ====================================================
        {
            "name": "📊 RAGEngine: Corpus Coverage Report",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/finiexragengine/cli/coverage_cli.py",
            "args": [
                "--pipeline",
                "${input:pipeline}"
            ],
            "console": "integratedTerminal",
            "justMyCode": false,
            "presentation": {
                "group": "04_diagnostics",
                "order": 2
            }
        },
        {
            "name": "📊 RAGEngine: Cost Report (real spend + projection)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/finiexragengine/cli/cost_cli.py",
            "args": [],
            "console": "integratedTerminal",
            "justMyCode": false,
            "presentation": {
                "group": "04_diagnostics",
                "order": 3
            }
        },
        {
            "name": "📊 RAGEngine: Performance Report",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/finiexragengine/cli/perf_cli.py",
            "args": [
                "--since",
                "7d"
            ],
            "console": "integratedTerminal",
            "justMyCode": false,
            "presentation": {
                "group": "04_diagnostics",
                "order": 4
            }
        },
        {
            "name": "📊 RAGEngine: Breaking Report (reaction + funnel)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/finiexragengine/cli/breaking_cli.py",
            "args": [
                "--since",
                "7d"
            ],
            "console": "integratedTerminal",
            "justMyCode": false,
            "presentation": {
                "group": "04_diagnostics",
                "order": 5
            }
        },
        {
            "name": "📊 RAGEngine: Model Check (ingest + llm stage vs available)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/finiexragengine/cli/models_cli.py",
            "console": "integratedTerminal",
            "justMyCode": false,
            "presentation": {
                "group": "04_diagnostics",
                "order": 6
            }
        },
        {
            "name": "📊 RAGEngine: Source Health Report (feeds + problems)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/finiexragengine/cli/sources_cli.py",
            "console": "integratedTerminal",
            "justMyCode": false,
            "presentation": {
                "group": "04_diagnostics",
                "order": 7
            }
        },
        {
            // Touches the feeds' network (no LLM/embeddings — no spend); resolves URLs from
            // the source-set configs. Omit --source to probe all feeds.
            "name": "📊 RAGEngine: Feed Doctor (raw output + parse diagnosis)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/finiexragengine/cli/feed_doctor_cli.py",
            "args": [],
            "console": "integratedTerminal",
            "justMyCode": false,
            "presentation": {
                "group": "04_diagnostics",
                "order": 8
            }
        },
        // ====================================================
        // Weekly
        // ====================================================
        {
            "name": "📊 RAGEngine: Weekly Report (console)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/finiexragengine/cli/report_cli.py",
            "args": [],
            "console": "integratedTerminal",
            "justMyCode": false,
            "presentation": {
                "group": "05_weekly",
                "order": 0
            }
        },
        {
            "name": "📨 RAGEngine: Weekly Report → Telegram (--send)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/finiexragengine/cli/report_cli.py",
            "args": [
                "--send"
            ],
            "console": "integratedTerminal",
            "justMyCode": false,
            "presentation": {
                "group": "05_weekly",
                "order": 1
            }
        },
        // ====================================================
        // output
        // ====================================================      
        {
            // The regular handgriff: only days that closed since the last export (reads the
            // archive_export_log DB flag). Idempotent, no re-writing the whole history. Same
            // mode the weekly report uses. No API cost.
            "name": "📦 RAGEngine: Export Outcomes — incremental (new closed days)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/finiexragengine/cli/export_cli.py",
            "args": [
                "--out",
                "data/signal_export",
                "--incremental"
            ],
            "console": "integratedTerminal",
            "justMyCode": false,
            "presentation": {
                "group": "06_output",
                "order": 0
            }
        },
        {
            // Whole closed days of the current ISO week (Mon 00:00 UTC onward), regardless of the
            // flag — but flags what it writes. Handy for re-cutting this week for a handover.
            "name": "📦 RAGEngine: Export Outcomes — since this week",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/finiexragengine/cli/export_cli.py",
            "args": [
                "--out",
                "data/signal_export",
                "--since",
                "week"
            ],
            "console": "integratedTerminal",
            "justMyCode": false,
            "presentation": {
                "group": "06_output",
                "order": 1
            }
        },
        {
            // Deliberate full re-export: every closed day, all-time (ignores the flag, flags all).
            // Explicit --all so a full rebuild is never accidental.
            "name": "📦 RAGEngine: Export Outcomes — ALL (all-time, deliberate)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/finiexragengine/cli/export_cli.py",
            "args": [
                "--out",
                "data/signal_export",
                "--all"
            ],
            "console": "integratedTerminal",
            "justMyCode": false,
            "presentation": {
                "group": "06_output",
                "order": 2
            }
        },
        {
            // One bucket: the day a YYYY-MM-DD falls into (prompted). Ignores the flag, flags it.
            "name": "📦 RAGEngine: Export Outcomes — single day",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/finiexragengine/cli/export_cli.py",
            "args": [
                "--out",
                "data/signal_export",
                "--day",
                "${input:day}"
            ],
            "console": "integratedTerminal",
            "justMyCode": false,
            "presentation": {
                "group": "06_output",
                "order": 3
            }
        },
        // ====================================================
        // 🗄 DATABASE MANAGEMENT (the schema itself — ISSUE_14)
        // ====================================================
        {
            // Read-only: what has been applied, what is waiting, what drifted.
            // Never changes the schema, so it is always safe to run.
            "name": "🗄 RAGEngine: Migration Status (read-only)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/finiexragengine/cli/migrate_cli.py",
            "args": [
                "--status"
            ],
            "console": "integratedTerminal",
            "justMyCode": false,
            "presentation": {
                "group": "07_database",
                "order": 1
            }
        },
        {
            // The ONLY writer of the schema: applies migrations/ in order, each in its own
            // transaction. Re-running is a no-op, so it is safe before every start — and the
            // engine refuses to boot while a migration is pending.
            // No API cost; it touches the database, not OpenAI.
            "name": "🗄 RAGEngine: Apply Migrations",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/finiexragengine/cli/migrate_cli.py",
            "args": [],
            "console": "integratedTerminal",
            "justMyCode": false,
            "presentation": {
                "group": "07_database",
                "order": 2
            }
        },
        // ====================================================
        // 🧩 TESTS (free — no API cost)
        // ====================================================
        {
            "name": "🧩 Pytest: All (free)",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": [
                "tests/",
                "-v"
            ],
            "console": "integratedTerminal",
            "justMyCode": false,
            "presentation": {
                "group": "02_tests",
                "order": 1
            }
        },
        {
            "name": "🧩💸 Pytest: Live RAG (OpenAI, paid)",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": [
                "tests/test_rag_live.py",
                "-m",
                "paid",
                "-v"
            ],
            "console": "integratedTerminal",
            "justMyCode": false,
            "presentation": {
                "group": "02_tests",
                "order": 2
            }
        },
    ],
    // Prompted at launch so the CLI entries can target any constellation.
    "inputs": [
        {
            "id": "pipeline",
            "type": "promptString",
            "description": "Pipeline id (configs/pipelines/<id>.json)",
            "default": "crypto_sentiment"
        },
        {
            "id": "symbol",
            "type": "promptString",
            "description": "Symbol to evaluate (e.g. BTCUSD)",
            "default": "BTCUSD"
        },
        {
            "id": "variant",
            "type": "promptString",
            "description": "Variant sub_pipeline_id — stream = <pipeline>_<variant> (ISSUE_42)",
            "default": "4o_enhanced"
        },
        {
            "id": "source_set",
            "type": "promptString",
            "description": "Source-set id (configs/source_sets/<id>.json)",
            "default": "crypto_news"
        },
        {
            "id": "day",
            "type": "promptString",
            "description": "Export the bucket this UTC day falls into (YYYY-MM-DD)",
            "default": "2026-07-21"
        }
    ]
}