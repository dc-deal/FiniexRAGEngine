{
    "name": "FiniexRAGEngine Dev",
    "dockerComposeFile": "../docker-compose.yml",
    "service": "ragengine",
    "workspaceFolder": "/app",
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-python.debugpy",
                "anthropic.claude-code"
            ],
            "settings": {
                "python.defaultInterpreterPath": "/usr/local/bin/python",
                "python.terminal.activateEnvironment": false
            }
        }
    },
    "forwardPorts": [8100],
    "postCreateCommand": "sh .devcontainer/restore_home.sh",
    "remoteUser": "root"
}
