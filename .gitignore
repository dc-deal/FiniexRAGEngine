# Byte-compiled / optimized
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution / packaging
build/
dist/
*.egg-info/
.eggs/

# Virtual environments
.venv/
venv/
env/

# Tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Secrets — never commit
.env
*.key

# Runtime data / logs
data/
logs/

# CLAUDE.md is published (the engineering rulebook — workflow transparency).
# Internal working docs stay private — never published.
INTERNAL_*.md
ISSUE_*.md
HANDOFF_*.md

# Local issue snapshot utility + its output (personal, never published)
export_github_issues.sh
github_issues/

# Local dev-home seed (personal state, restored after container rebuilds)
.devcontainer/local/

# OS / editor
.DS_Store
